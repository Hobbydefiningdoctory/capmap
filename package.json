{
  "name": "capman",
  "version": "0.1.0",
  "description": "Capability Manifest Engine — let AI agents interact with your app without navigating the UI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "capman": "./bin/capman.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "tsx examples/basic.ts",
    "validate": "node bin/capman.js validate",
    "inspect": "node bin/capman.js inspect"
  },
  "keywords": [
    "ai",
    "agent",
    "manifest",
    "capability",
    "navigation",
    "llm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "zod": "catalog:"
  }
}