# Copy this file to .env and fill in your values
# Never commit .env — it is git-ignored

# DeepSeek API key (used by test/test-conduit-llm.ts)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Replit AI integration (auto-set by Replit — no action needed on Replit)
# When running locally, set these to your own OpenAI-compatible endpoint:
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
